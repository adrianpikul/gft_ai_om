{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "bash gft_ai_om/copilot_usage/scripts/collect-copilot-usage.sh SessionStart",
        "windows": "powershell -File gft_ai_om\\copilot_usage\\scripts\\collect-copilot-usage.ps1 -EventName SessionStart",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "bash gft_ai_om/copilot_usage/scripts/collect-copilot-usage.sh UserPromptSubmit",
