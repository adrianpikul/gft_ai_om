        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "ErrorOccurred": [
      {
        "type": "command",
        "command": "bash gft_ai_om/copilot_usage/scripts/collect-copilot-usage.sh ErrorOccurred",
        "windows": "powershell -File gft_ai_om\\copilot_usage\\scripts\\collect-copilot-usage.ps1 -EventName ErrorOccurred",
